# Alibaba Open Platform (API pool + image download)
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
NEXT_PUBLIC_ALIBABA_APP_KEY=

# Playwright: false = headed browser (login uses headed browser via npm run playwright-login)
PLAYWRIGHT_HEADLESS=false

# Duplicate method: playwright (default) or api
DUPLICATE_METHOD=playwright

# Seller Center "Last updated" calendar timezone for duplicate pool (default: America/Los_Angeles)
# LISTING_POOL_TIMEZONE=America/Los_Angeles

# Optional photobank group for image prep uploads
# PHOTOBANK_GROUP_ID=
